<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>AgentProvisioner</RootNamespace>
    <AssemblyName>agent-provisioner</AssemblyName>
  </PropertyGroup>

  <!--
    T020: idempotently registers the morning-brief agent version in Azure AI Foundry
    via PersistentAgentsClient + DefaultAzureCredential. No-ops without Foundry creds.
  -->
  <ItemGroup>
    <PackageReference Include="Azure.AI.Agents.Persistent" />
    <PackageReference Include="Azure.Identity" />
  </ItemGroup>

  <!-- Ship the agent prompt (authored in orchestration-api/Prompts) with this job so it
       can read the same instructions the LIVE runner uses (T017/T019 parity). -->
  <ItemGroup>
    <Content Include="..\orchestration-api\Prompts\morning-brief.md"
             Link="Prompts\morning-brief.md"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
