# Copy to .env to configure the WF-Garage demo (T005). NO SECRET VALUES here —
# real secrets come from Azure Key Vault in deployment. DEMO mode runs fully
# offline with no credentials.

# --- Run mode -------------------------------------------------------------
# 1 = deterministic offline DEMO (default). Set to 0 (or MODE=LIVE) for Foundry.
DEMO_MODE=1

# --- Mock system-of-record API -------------------------------------------
# Base URL the orchestration API calls for all tool data (HTTP seam, FR-002).
MOCK_API_BASEURL=http://localhost:8080

# --- Azure AI Foundry (LIVE mode only) -----------------------------------
# Populated from Key Vault / Terraform outputs in deployment. Leave blank for DEMO.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4.1

# Maximum agent tool-calling hops in LIVE mode (caps runaway tool loops, FR-011).
MAX_TOOL_HOPS=8
