# Copy to .env to configure WF-Garage. Do not put secret values in this file.
# DEMO mode is deterministic, offline, and requires no Azure credentials.

# --- Run mode -------------------------------------------------------------
# 1 = deterministic offline DEMO (default). Set to 0 for Azure AI Foundry LIVE mode.
DEMO_MODE=1

# --- Mock system-of-record API -------------------------------------------
# Base URL the orchestration API calls for all tool data (HTTP seam, FR-002).
# docker-compose overrides this to http://mock-api:8080.
MOCK_API_BASEURL=http://localhost:8080

# --- Azure AI Foundry (LIVE mode only) -----------------------------------
# Use Terraform outputs for deployed environments:
#   terraform -chdir=infra output -raw foundry_project_endpoint
#   terraform -chdir=infra output -raw foundry_model_deployment
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4o-mini-deployment

# Per-role model deployments (each on its OWN deployment = separate quota pool) so the
# fanned-out event-specialist and the synthesizers never contend for the same TPM/RPM —
# this is what stops the 429 throttling. Both fall back to FOUNDRY_MODEL if unset.
#   terraform -chdir=infra output -raw foundry_morning_model_deployment
#   terraform -chdir=infra output -raw foundry_specialist_model_deployment
FOUNDRY_MODEL_MORNING=gpt-4o-mini-deployment
FOUNDRY_MODEL_SPECIALIST=gpt-5.4-nano-deployment

# Maximum agent tool-calling hops in LIVE mode (caps runaway tool loops, FR-011).
MAX_TOOL_HOPS=8

# Per-event multi-agent fan-out concurrency in LIVE mode (002 US4). One event-specialist runs per
# current event, bounded by this cap.
EVENT_FANOUT_MAX_CONCURRENCY=4

# Retry-with-backoff for transient model throttling (HTTP 429 rate_limit_exceeded / 503 / 408).
# Honors a server Retry-After, otherwise exponential backoff with full jitter. Raise the model
# deployment quota for heavy live use; these only smooth short bursts.
FOUNDRY_RETRY_MAX_ATTEMPTS=4
FOUNDRY_RETRY_BASE_DELAY_MS=500

# --- Browser/API security -------------------------------------------------
# Comma-separated allowed origins for orchestration-api CORS.
# Leave blank for local development fallback AllowAnyOrigin; Terraform sets the deployed ui-app origin.
CORS_ALLOWED_ORIGINS=

# Optional Entra ID JWT-bearer validation scaffolding for secured scenes.
AZURE_AD_AUTHORITY=
AZURE_AD_AUDIENCE=

# --- Observability --------------------------------------------------------
# Optional OTLP collector endpoint. Leave blank for offline DEMO mode.
OTEL_EXPORTER_OTLP_ENDPOINT=
