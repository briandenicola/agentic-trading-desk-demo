# Copy to .env and fill in to enable LIVE agent mode.
# Leave unset (or DEMO_MODE=1) to run the deterministic offline demo.

# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Base URL the agent tools call for mock data (defaults to the local server).
# MOCK_API_BASE=http://localhost:8000

# Force deterministic demo mode even if a key is present (recommended on stage).
# DEMO_MODE=1
