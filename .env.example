# Copy to .env to configure WF-Garage. Do not put secret values in this file.
# DEMO mode is deterministic, offline, and requires no Azure credentials.

# --- Run mode -------------------------------------------------------------
# 1 = deterministic offline DEMO (default). Set to 0 for Azure AI Foundry LIVE mode.
DEMO_MODE=1

# --- Mock system-of-record API -------------------------------------------
# Base URL the orchestration API calls for all tool data (HTTP seam, FR-002).
# docker-compose overrides this to http://mock-api:8080.
MOCK_API_BASEURL=http://localhost:8080

# --- Azure AI Foundry (LIVE mode only) -----------------------------------
# Use Terraform outputs for deployed environments:
#   terraform -chdir=infra output -raw foundry_project_endpoint
#   terraform -chdir=infra output -raw foundry_model_deployment
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4o-mini-deployment

# Maximum agent tool-calling hops in LIVE mode (caps runaway tool loops, FR-011).
MAX_TOOL_HOPS=8

# --- Browser/API security -------------------------------------------------
# Comma-separated allowed origins for orchestration-api CORS.
# Leave blank for local development fallback AllowAnyOrigin; Terraform sets the deployed ui-app origin.
CORS_ALLOWED_ORIGINS=

# Optional Entra ID JWT-bearer validation scaffolding for secured scenes.
AZURE_AD_AUTHORITY=
AZURE_AD_AUDIENCE=

# --- Observability --------------------------------------------------------
# Optional OTLP collector endpoint. Leave blank for offline DEMO mode.
OTEL_EXPORTER_OTLP_ENDPOINT=
